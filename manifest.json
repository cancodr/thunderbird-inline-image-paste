{
  "manifest_version": 2,
  "name": "Inline Image Paste Plus",
  "version": "1.0.1",
  "description": "Paste clipboard images inline in Thunderbird with PNG, JPG, or automatic format selection.",
  "author": "Cancodr",
  "homepage_url": "https://github.com/Cancodr/thunderbird-inline-image-paste",

  "browser_specific_settings": {
    "gecko": {
      "id": "inline-image-paste-plus@cancodr",
      "strict_min_version": "115.0"
    }
  },

  "permissions": [
    "compose",
    "storage",
    "tabs"
  ],

  "background": {
    "scripts": [
      "background.js"
    ]
  },

  "compose_action": {
    "default_title": "Inline Paste",
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icon-32.png",
      "64": "icons/icon-64.png"
    }
  },

  "icons": {
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}